# EDUCATIONAL NOTE: This template documents every environment variable the stack
# consumes. Copy it to `.env` (which is gitignored) and fill in real values:
#   cp .env.example .env
# docker compose loads `.env` automatically from this directory. Never commit `.env`.

# --- Required ---

# Gemini API key used by the orchestrator to call the LLM (get one at https://aistudio.google.com/).
GEMINI_API_KEY=your-gemini-api-key-here

# --- Common options (compose passes these through to the orchestrator) ---

# LLM model the orchestrator routes with (compose falls back to gemini-1.5-flash if unset).
AGENT_MODEL=gemini-2.5-flash

# Use the public Gemini API (0) rather than Vertex AI (1); this lab uses API-key auth.
GOOGLE_GENAI_USE_VERTEXAI=0

# Session-history backend: in_memory | redis | postgres (redis is the compose default; Redis runs in ../nexus-dev-infra).
PERSISTENCE_BACKEND=redis

# Base URL of a local Ollama server, only used when AGENT_MODEL is an ollama/* model.
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional overrides (sensible defaults ship in docker-compose.yml / orchestrator config) ---

# Optional: alternative key variable honored by the orchestrator when GEMINI_API_KEY is unset.
#GOOGLE_API_KEY=

# Optional: comma-separated MCP server SSE endpoints (default: the in-stack mcp-server service).
#MCP_SERVER_URLS=http://mcp-server:8000/sse

# Optional: comma-separated A2A endpoints for dynamic discovery (default: the in-stack
# a2a-agent service). Base URLs get /.well-known/agent-card.json appended; each reachable
# card registers one agent, named from the card (e.g. "Weather Sub-Agent" -> weather_sub_agent).
#A2A_AGENT_URLS=http://a2a-agent:8001/.well-known/agent-card.json

# Optional: reviewer-critic enforcement on ALL orchestrator responses (CLI and HTTP).
# Default: true. Set false to demo the difference without the QA review pass.
#REVIEWER_ENFORCEMENT=true

# Optional: host port the orchestrator is published on (default 8080). Set this if
# something on your machine already listens on 8080 — the VM port-forward fails
# silently in that case while the container still reports healthy. make demo picks
# this up automatically; rebuild the UI with a matching VITE_API_BASE_URL for browser use.
#ORCHESTRATOR_HOST_PORT=8080

# Optional: host port the web UI is published on (default 5173 — Vite's default dev
# port, so it's often taken). Same silent-failure caveat as above.
#FRONTEND_HOST_PORT=5173

# NOTE: REDIS_URL, POSTGRES_URL, PROMETHEUS_URL, MCP_SERVER_URL, A2A_AGENT_URL and the
# OTEL_* endpoints are wired directly in docker-compose.yml to service names on the
# shared nexus-net network — you normally never set them here.

# --- UI build-time variables (NOT read from this file) ---
# The frontend is built on the host (`make build` runs `npm run build` in ../nexus-ui),
# so Vite bakes these in at build time; export them in your shell before building:
#   VITE_API_BASE_URL   - orchestrator base URL for the browser (default http://localhost:8080)
#   VITE_GRAFANA_URL    - Grafana base URL for trace links (default http://localhost:3000)
#   VITE_OTEL_EXPORTER_URL - OTLP collector URL for browser telemetry (default http://localhost:4319)
